{
  "manifest_version": 3,
  "name": "Hello World",
  "version": "1.0.0",
  "description": "一个简单的 Hello World 浏览器插件",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hello World",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
